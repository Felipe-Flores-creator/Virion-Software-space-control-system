{
    "name": "sig-pro",
    "version": "1.0.0",
    "description": "Sistema de Información Geográfica Profesional",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "concurrently \"python ../python_api/app.py\" \"electron .\"",
        "build": "electron-builder",
        "build:win": "electron-builder --win --x64",
        "build:mac": "electron-builder --mac --x64",
        "build:linux": "electron-builder --linux --x64",
        "pack": "electron-builder --dir",
        "postinstall": "electron-builder install-app-deps"
    },
    "keywords": [
        "gis",
        "sig",
        "geographic",
        "mapping",
        "desktop"
    ],
    "author": "Felipe Flores",
    "license": "MIT",
    "build": {
        "appId": "com.sigpro.app",
        "productName": "SIG Pro",
        "copyright": "Copyright © 2024 SIG Pro",
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!node_modules/",
            "!node_modules/*",
            "!python_api/",
            "!src/",
            "!vite.config.js",
            "!package-lock.json",
            "!README.md"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.ico"
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.icns"
        },
        "linux": {
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "assets/icon.ico",
            "uninstallerIcon": "assets/icon.ico",
            "installerHeaderIcon": "assets/icon.ico",
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    },
    "dependencies": {
        "electron-squirrel-startup": "^1.0.0",
        "node-fetch": "^3.3.2"
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "electron": "^28.0.0",
        "electron-builder": "^24.13.3",
        "electron-packager": "^17.1.1"
    }
}